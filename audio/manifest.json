    "ponce_first_contact_00.mp3": {
      "scenario_id": "ponce_first_contact",
      "line_index": 0,
      "text": "Somos enviados por el Rey de Espana. Venimos en paz.",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
    "ponce_first_contact_02.mp3": {
      "scenario_id": "ponce_first_contact",
      "line_index": 2,
      "text": "Traemos la palabra de Dios y regalos para vuestro cacique.",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
    "ponce_first_contact_05.mp3": {
      "scenario_id": "ponce_first_contact",
      "line_index": 5,
      "text": "Nos atacan! A las armas!",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
    "fontaneda_captivity_00.mp3": {
      "scenario_id": "fontaneda_captivity",
      "line_index": 0,
      "text": "No me mateis, por Dios. Soy cristiano, soy solamente un nino.",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
    "fontaneda_captivity_02.mp3": {
      "scenario_id": "fontaneda_captivity",
      "line_index": 2,
      "text": "Vengo de Cartagena de Indias. Mi navio se hundio en la tormenta.",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
    "menendez_carlos_00.mp3": {
      "scenario_id": "menendez_carlos",
      "line_index": 0,
      "text": "El Rey Felipe, nuestro senor, os ofrece su amistad y proteccion.",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
    "menendez_carlos_03.mp3": {
      "scenario_id": "menendez_carlos",
      "line_index": 3,
      "text": "Deseo la paz entre nuestros pueblos. Tomare a vuestra hermana por esposa.",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
    "menendez_carlos_05.mp3": {
      "scenario_id": "menendez_carlos",
      "line_index": 5,
      "text": "Os daremos herramientas de hierro y telas finas.",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
    "mission_estero_00.mp3": {
      "scenario_id": "mission_estero",
      "line_index": 0,
      "text": "Hay un solo Dios verdadero, el Dios de los cristianos.",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
    "mission_estero_02.mp3": {
      "scenario_id": "mission_estero",
      "line_index": 2,
      "text": "Debeis abandonar vuestros idolos. Son obra del demonio.",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
    "mission_estero_05.mp3": {
      "scenario_id": "mission_estero",
      "line_index": 5,
      "text": "Que Dios tenga piedad de vuestras almas.",
      "speaker": "spanish",
      "voice_id": "diKn1AGR1UOOaW8J7qoL"
    },
